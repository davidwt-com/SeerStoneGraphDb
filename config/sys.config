[
  {kernel, [
    {logger_level, info},
    {logger, [
      %% Console handler — errors and above to stdout.
      {handler, default, logger_std_h, #{
        config    => #{type => standard_io},
        level     => error,
        formatter => {logger_formatter, #{
          template => [time, " [", level, "] ", mfa, ":", line, " -- ", msg, "\n"]
        }}
      }},

      %% File handler — info and above to a rotating log file.
      {handler, file_handler, logger_std_h, #{
        config => #{
          type            => {file, "log/seerstone.log"},
          file_check      => 5000,
          max_no_bytes    => 10485760,  %% 10 MB per segment
          max_no_files    => 5
        },
        level     => info,
        formatter => {logger_formatter, #{
          template => [time, " [", level, "] ", mfa, ":", line, " -- ", msg, "\n"]
        }}
      }}
    ]}
  ]},

  {seerstone_graph_db, [
    {app_port,   8080},
    {data_path,  "data"},
    {index_path, "index"}
  ]}
].
