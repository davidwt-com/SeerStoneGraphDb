{erl_opts, [debug_info]}.

{deps, []}.

{relx, [
    {release, {seerstone, "0.1.0"},
     [nref,
      database,
      seerstone]},
    {sys_config, "config/sys.config"},
    {dev_mode, true},
    {include_erts, false}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]}
]}.
